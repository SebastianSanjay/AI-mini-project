# FastAPI Server
PORT=8000
DEBUG=True

# Postgres Database
DATABASE_URL=postgresql+asyncpg://admin:password@postgres:5432/linguafuse
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=linguafuse

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage

# AI Providers Config
# Options: coqui, elevenlabs
TTS_PROVIDER=coqui
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Options: seamlessm4t, google
TRANSLATION_PROVIDER=seamlessm4t
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# Wav2Lip config
WAV2LIP_CHECKPOINT_PATH=./models/checkpoints/wav2lip_gan.pth

# Coqui TTS
COQUI_TOS_AGREED=1
